{
  "name": "xtronexcel",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "compile": "tsc -p tsconfig.node.json",
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"npm run compile && electron .\"",
    "build": "vite build && npm run compile",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.datum.xtronexcel",
    "productName": "XtronExcel",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-react/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.6.0",
    "@reduxjs/toolkit": "^2.2.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.5"
  }
}
